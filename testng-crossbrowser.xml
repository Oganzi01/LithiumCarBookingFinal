<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Final Regression Suite" parallel="tests" thread-count="2">

    <listeners>
        <listener class-name="com.carbooking.gui.listeners.AllureListener"/>
    </listeners>

    <test name="API Suite">
        <packages>
            <package name="com.carbooking.api.*"/>
        </packages>
    </test>

    <test name="UI Chrome">
        <parameter name="browser" value="chrome"/>
        <packages>
            <package name="com.carbooking.gui.tests.*"/>
        </packages>
    </test>

    <test name="UI Firefox">
        <parameter name="browser" value="firefox"/>
        <packages>
            <package name="com.carbooking.gui.tests.*"/>
        </packages>
    </test>

</suite>