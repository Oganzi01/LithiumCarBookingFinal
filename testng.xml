<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Lithium Car Booking Project">

    <listeners>
        <listener class-name="com.carbooking.gui.utils.TestListener"/>
    </listeners>

    <test name="UI_Tests">
        <parameter name="browser" value="chrome"/>
        <packages>
            <package name="com.carbooking.gui.tests.positive"/>
            <package name="com.carbooking.gui.tests.negative"/>
        </packages>
    </test>

    <test name="API_Tests">
        <packages>
            <package name="com.carbooking.gui.taskApp.api.tests"/>
        </packages>
    </test>

</suite>