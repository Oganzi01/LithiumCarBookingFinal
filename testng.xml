<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Full Test Suite" parallel="tests" thread-count="3">

    <!-- UI Chrome -->
    <test name="UI Chrome Tests">
        <parameter name="browser" value="chrome"/>
        <packages>
            <package name="com.carbooking.gui.tests"/>
        </packages>
    </test>

    <!-- UI Firefox -->
    <test name="UI Firefox Tests">
        <parameter name="browser" value="firefox"/>
        <packages>
            <package name="com.carbooking.gui.tests"/>
        </packages>
    </test>

    <!-- API Tests -->
    <test name="API Tests">
        <packages>
            <package name="com.carbooking.api.tests"/>
        </packages>
    </test>

</suite>